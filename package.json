{'name': 'llmeld', 'version': '0.1.0', 'description': 'Dual-surface API gateway with cloud planner + local executor orchestration', 'type': 'module', 'main': 'dist/index.js', 'scripts': {'dev': 'tsx watch src/index.ts', 'dev:local-only': 'LLMELD_ROUTING_MODE=local tsx watch src/index.ts', 'build': 'tsc', 'start': 'node dist/index.js', 'test': 'vitest run', 'test:watch': 'vitest', 'lint': 'eslint src/ --ext .ts', 'lint:fix': 'eslint src/ --ext .ts --fix', 'format': "prettier --write 'src/**/*.ts'", 'typecheck': 'tsc --noEmit', 'build:ezyBiz': 'cd android && ./gradlew assembleEzyBizRelease && cd ..', 'build:callConcierge': 'cd android && ./gradlew assembleCallConciergeRelease && cd ..', 'run:ezyBiz': 'npx react-native run-android --variant=ezyBizDebug', 'run:callConcierge': 'npx react-native run-android --variant=callConciergeDebug', 'ios:ezyBiz': "npx react-native run-ios --scheme 'EzyBiz'", 'ios:callConcierge': "npx react-native run-ios --scheme 'CallConcierge'"}, 'keywords': ['llm', 'gateway', 'openai', 'anthropic', 'ollama', 'openrouter'], 'license': 'MIT', 'engines': {'node': '>=20.0.0'}, 'dependencies': {'chalk': '^5.3.0', 'dotenv': '^17.4.2', 'enquirer': '^2.4.1', 'fastify': '^5.8.5', 'pino': '^10.3.1', 'pino-pretty': '^13.1.3', 'undici': '^8.1.0', 'uuid': '^13.0.0', 'yaml': '^2.8.3', 'zod': '^4.3.6'}, 'devDependencies': {'@types/node': '^25.6.0', '@types/uuid': '^11.0.0', '@typescript-eslint/eslint-plugin': '^8.58.2', '@typescript-eslint/parser': '^8.58.2', 'eslint': '^10.2.0', 'prettier': '^3.8.3', 'tsx': '^4.21.0', 'typescript': '^6.0.2', 'vitest': '^4.1.4'}}